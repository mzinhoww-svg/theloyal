{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theloyalty/edition.schema.json",
  "title": "The Loyal — Edição do Daily",
  "description": "Modelo editorial único que alimenta e-mail, plain text e página web. Ancorado no Operating Manual v1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["number", "date", "weekday", "publishTime", "readingMinutes", "signal", "deals", "sources", "disclaimer"],
  "properties": {
    "number": { "type": "integer", "minimum": 1, "description": "Número da edição" },
    "date": { "type": "string", "format": "date", "description": "Data de publicação (ISO)" },
    "weekday": { "type": "string", "description": "Dia da semana em CAPS, ex: TERÇA-FEIRA" },
    "publishTime": { "type": "string", "description": "Horário, ex: 8H00" },
    "readingMinutes": { "type": "integer", "minimum": 1, "maximum": 15 },
    "illustrative": { "type": "boolean", "description": "Marca a edição como exemplo/ilustrativa" },
    "subject": { "type": "string", "description": "Assunto do e-mail" },
    "preheader": { "type": "string", "description": "Preheader do e-mail" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "description": "Slug do post no Beehiiv (web_settings.slug). Ausente ⇒ derivado de productType+número." },
    "tags": { "type": "array", "items": { "type": "string" }, "description": "content_tags do post no Beehiiv" },
    "productType": { "type": "string", "enum": ["daily", "pro"], "description": "Tipo de produto. Default: daily." },
    "scheduledAt": { "type": "string", "format": "date-time", "description": "Agendamento do envio (ISO). Alimenta scheduled_at no Beehiiv." },
    "signal": { "type": "string", "minLength": 1, "description": "O sinal do dia" },
    "deals": {
      "type": "array",
      "description": "Deal Desk — oportunidades com conta feita",
      "items": { "$ref": "#/$defs/deal" }
    },
    "fechaLogo": {
      "type": "array",
      "description": "Itens que vencem em até 72h",
      "items": { "$ref": "#/$defs/fecha" }
    },
    "shoppingWatch": {
      "type": "array",
      "description": "Radar de VPM observado no não-aéreo (Shopping): custo de fabricação de resgate por player, derivado de preço público de catálogo. Nunca CMI interno.",
      "items": { "$ref": "#/$defs/shopping" }
    },
    "radar": {
      "type": "object",
      "description": "Radar de janelas — projeção estatística por recorrência do ledger. Não é veredito nem garantia.",
      "additionalProperties": false,
      "required": ["windows"],
      "properties": {
        "note": { "type": "string", "description": "Nota de humildade. Ausente ⇒ usa o padrão." },
        "windows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/radarWindow" }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "disclaimer": {
      "type": "string",
      "const": "Promoções podem mudar sem aviso. Confira sempre as regras no site oficial antes de comprar, transferir ou resgatar.",
      "description": "Frase oficial obrigatória, íntegra"
    }
  },
  "$defs": {
    "verdict": {
      "type": "string",
      "enum": ["vale-agir", "vale-olhar", "casos-especificos", "esperaria", "evitaria", "nao-confirmado"]
    },
    "conta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows", "result"],
      "description": "Conta feita: pares chave/valor + resultado. Números em mono no render.",
      "properties": {
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
        },
        "result": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
      }
    },
    "scoreBreakdown": {
      "type": "object",
      "description": "Os 8 critérios do TL Score (0–100 cada). Soma ponderada (25/15/15/10/10/10/10/5) deve fechar com tlScore.",
      "additionalProperties": false,
      "properties": {
        "valor": { "type": "number", "minimum": 0, "maximum": 100 },
        "regra": { "type": "number", "minimum": 0, "maximum": 100 },
        "vigencia": { "type": "number", "minimum": 0, "maximum": 100 },
        "friccao": { "type": "number", "minimum": 0, "maximum": 100 },
        "aplicabilidade": { "type": "number", "minimum": 0, "maximum": 100 },
        "liquidez": { "type": "number", "minimum": 0, "maximum": 100 },
        "estoque": { "type": "number", "minimum": 0, "maximum": 100 },
        "fontes": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "deal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "title", "context", "conta", "verdict", "source"],
      "properties": {
        "category": { "type": "string", "description": "Ex: Transferência bonificada · Livelo → Smiles" },
        "title": { "type": "string" },
        "context": { "type": "string" },
        "conta": { "$ref": "#/$defs/conta" },
        "verdict": { "$ref": "#/$defs/verdict" },
        "verdictNote": { "type": "string" },
        "source": { "type": "string", "description": "Fonte + status de vigência" },
        "sourceUrl": { "type": "string", "format": "uri" },
        "vigencia": { "type": "string", "format": "date-time", "description": "Fim da vigência (ISO). Ausente ⇒ verdict deve ser nao-confirmado (overrule 5.4)" },
        "tlScore": { "type": "integer", "minimum": 0, "maximum": 100 },
        "scoreBreakdown": { "$ref": "#/$defs/scoreBreakdown" },
        "entityKey": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "description": "Chave canônica do deal em content/entities (identidade do Fio na consolidação Weekly). Ausente ⇒ não rastreável na Weekly (aviso, não erro)." },
        "routeKey": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*->[a-z0-9]+(?:-[a-z0-9]+)*$", "description": "Rota origem->destino normalizada (entity keys), para deals de transferência. Identidade estável independente de vigencia_fim (ADR-RADAR-009)." },
        "firstSeen": { "type": "string", "format": "date", "description": "1ª aparição do fato (ISO date). Distingue NOVO de SEGUE na consolidação Weekly sem heurística." }
      }
    },
    "shopping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["player", "category", "vpmObservado", "source"],
      "description": "Uma leitura de VPM observado (R$/milheiro) por player/categoria. vpmObservado = 'n/c' quando a amostra é insuficiente.",
      "properties": {
        "player": { "type": "string", "description": "Ex: LATAM Pass, Azul, Smiles" },
        "category": { "type": "string", "description": "Ex: smartphone, tv, notebook" },
        "vpmObservado": { "type": "string", "description": "R$/milheiro observado, ou 'n/c'. Em mono no render." },
        "sampleN": { "type": "integer", "minimum": 0, "description": "Tamanho da amostra após limpar promo/outliers" },
        "source": { "type": "string", "description": "Fonte pública (catálogo) + status" },
        "sourceUrl": { "type": "string", "format": "uri", "pattern": "^https?://" },
        "observedAt": { "type": "string", "format": "date-time" }
      }
    },
    "fecha": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "text"],
      "properties": {
        "tag": { "type": "string", "description": "Ex: VENCE EM 48H" },
        "text": { "type": "string" },
        "cpm": { "type": "string", "description": "CPM em mono, ex: CPM R$ 24,90" },
        "note": { "type": "string" },
        "vigencia": { "type": "string", "format": "date-time" }
      }
    },
    "radarWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "confidence", "window"],
      "description": "Uma janela prevista. label = programa ou rota; window = texto (mono no render).",
      "properties": {
        "label": { "type": "string", "description": "Ex: Latam Pass · Itaú → Latam Pass" },
        "confidence": { "type": "string", "enum": ["alta", "media", "baixa"], "description": "Confiança da projeção. em-formacao nunca vira linha de radar." },
        "window": { "type": "string", "description": "Janela prevista, ex: 17 a 24 jul" },
        "basis": { "type": "string", "description": "Base da projeção (cadência, nº de janelas)" },
        "bonus": { "type": "string", "description": "Bônus típico em mono, ex: ~23%" },
        "source": { "type": "string", "description": "Proveniência (Fase C0). 'forecast' = automático (deve bater com content/forecast.json); ausente = análise editorial." },
        "seriesKey": { "type": "string", "description": "Chave da série no forecast automático (proveniência)." },
        "generatedAt": { "type": "string", "description": "Quando o número automático foi gerado (proveniência/frescor)." }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
      }
    }
  }
}
