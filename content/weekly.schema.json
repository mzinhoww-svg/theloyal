{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theloyalty/weekly.schema.json",
  "title": "The Loyal — Weekly digest",
  "description": "Digest semanal centrado no Radar de janelas (previsão) e nos movimentos do ledger na semana. Tom analítico, mesmas regras invioláveis do daily.",
  "type": "object",
  "additionalProperties": false,
  "required": ["number", "period", "dateStart", "dateEnd", "publishTime", "readingMinutes", "signal", "watch", "sources", "disclaimer"],
  "properties": {
    "number": { "type": "integer", "minimum": 1 },
    "period": { "type": "string", "description": "Período por extenso, ex: Semana de 7 a 13 de julho" },
    "dateStart": { "type": "string", "format": "date" },
    "dateEnd": { "type": "string", "format": "date" },
    "publishTime": { "type": "string" },
    "readingMinutes": { "type": "integer", "minimum": 1, "maximum": 15 },
    "illustrative": { "type": "boolean" },
    "subject": { "type": "string" },
    "preheader": { "type": "string" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "signal": { "type": "string", "minLength": 1, "description": "Tese da semana" },
    "radar": {
      "type": "object",
      "description": "Radar de janelas — centro do weekly. Ausente ⇒ o render puxa digest.radarWeekly de content/forecast.json.",
      "additionalProperties": false,
      "required": ["windows"],
      "properties": {
        "note": { "type": "string" },
        "windows": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/radarWindow" } }
      }
    },
    "movements": {
      "type": "object",
      "description": "Movimentos do ledger na semana, por Fio. Itens aceitam string (legado) ou objeto com lineage (consolidação automática).",
      "additionalProperties": false,
      "properties": {
        "novas": { "type": "array", "items": { "$ref": "#/$defs/movementItem" }, "description": "Fios que abriram (ou reabriram)" },
        "venceram": { "type": "array", "items": { "$ref": "#/$defs/movementItem" }, "description": "Fios que encerraram ou viraram" },
        "seguem": { "type": "array", "items": { "$ref": "#/$defs/movementItem" }, "description": "Fios que continuam vigentes" }
      }
    },
    "ranking": {
      "type": "array",
      "description": "Onde está o valor na semana — Fios vivos e confirmados, ordenados por chave auditável. Sugerido pela máquina, aprovado por humano.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "fio", "verdict"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "fio": { "type": "string", "description": "Chave do Fio (routeKey/entityKey)." },
          "label": { "type": "string", "description": "Rótulo humano do Fio (ex: Transferência bonificada · Esfera → Latam Pass)." },
          "anchor": { "type": "string", "description": "Número-âncora da semana (ex: CPM R$ 12,00). Em mono no render." },
          "verdict": { "type": "string", "enum": ["vale-agir", "vale-olhar", "casos-especificos", "esperaria", "evitaria", "nao-confirmado"] },
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "lineage": { "$ref": "#/$defs/lineage" }
        }
      }
    },
    "highlights": {
      "type": "array",
      "description": "Destaques do período (opcional) — os Fios que mudaram a foto.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "note"],
        "properties": {
          "fio": { "type": "string", "description": "Chave do Fio — usada na dedup de saída (um Fio, um bloco)." },
          "title": { "type": "string" },
          "note": { "type": "string" },
          "verdict": { "type": "string", "enum": ["vale-agir", "vale-olhar", "casos-especificos", "esperaria", "evitaria", "nao-confirmado"] },
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "transition": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to"],
            "description": "Transição de veredito na semana (VIROU).",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" }
            }
          },
          "lineage": { "$ref": "#/$defs/lineage" }
        }
      }
    },
    "watch": { "type": "array", "minItems": 1, "items": { "type": "string" }, "description": "O que monitorar na próxima semana" },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
    "disclaimer": {
      "type": "string",
      "const": "Promoções podem mudar sem aviso. Confira sempre as regras no site oficial antes de comprar, transferir ou resgatar."
    }
  },
  "$defs": {
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edition", "deal"],
      "description": "Proveniência até a Daily de origem (padrão derivedFrom do Pro).",
      "properties": {
        "edition": { "type": "integer", "minimum": 1 },
        "deal": { "type": "integer", "minimum": 0 }
      }
    },
    "movementItem": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text"],
          "properties": {
            "text": { "type": "string" },
            "fio": { "type": "string" },
            "lineage": { "$ref": "#/$defs/lineage" }
          }
        }
      ]
    },
    "radarWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "confidence", "window"],
      "properties": {
        "label": { "type": "string" },
        "confidence": { "type": "string", "enum": ["alta", "media", "baixa"] },
        "window": { "type": "string" },
        "basis": { "type": "string" },
        "bonus": { "type": "string" },
        "source": { "type": "string", "description": "Proveniência (Fase C0): 'forecast' = automático; ausente = análise editorial." },
        "seriesKey": { "type": "string" },
        "generatedAt": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
      }
    }
  }
}
