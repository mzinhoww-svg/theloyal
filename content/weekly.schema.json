{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theloyalty/weekly.schema.json",
  "title": "The Loyal — Weekly digest",
  "description": "Digest semanal centrado no Radar de janelas (previsão) e nos movimentos do ledger na semana. Tom analítico, mesmas regras invioláveis do daily.",
  "type": "object",
  "additionalProperties": false,
  "required": ["number", "period", "dateStart", "dateEnd", "publishTime", "readingMinutes", "signal", "watch", "sources", "disclaimer"],
  "properties": {
    "number": { "type": "integer", "minimum": 1 },
    "period": { "type": "string", "description": "Período por extenso, ex: Semana de 7 a 13 de julho" },
    "dateStart": { "type": "string", "format": "date" },
    "dateEnd": { "type": "string", "format": "date" },
    "publishTime": { "type": "string" },
    "readingMinutes": { "type": "integer", "minimum": 1, "maximum": 15 },
    "illustrative": { "type": "boolean" },
    "subject": { "type": "string" },
    "preheader": { "type": "string" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "consolidateFromDaily": { "type": "boolean", "description": "Quando true, o render substitui highlights pela consolidação automática das edições Daily do período (Fase 2.1). Cada highlight referencia sourceEditions e herda a disposição mais restritiva — a Weekly nunca sobe a régua." },
    "signal": { "type": "string", "minLength": 1, "description": "Tese da semana" },
    "radar": {
      "type": "object",
      "description": "Radar de janelas — centro do weekly. Ausente ⇒ o render puxa digest.radarWeekly de content/forecast.json.",
      "additionalProperties": false,
      "required": ["windows"],
      "properties": {
        "note": { "type": "string" },
        "windows": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/radarWindow" } }
      }
    },
    "movements": {
      "type": "object",
      "description": "Movimentos do ledger na semana.",
      "additionalProperties": false,
      "properties": {
        "novas": { "type": "array", "items": { "type": "string" }, "description": "Campanhas que abriram" },
        "venceram": { "type": "array", "items": { "type": "string" }, "description": "Campanhas que encerraram" },
        "seguem": { "type": "array", "items": { "type": "string" }, "description": "Campanhas que continuam" }
      }
    },
    "highlights": {
      "type": "array",
      "description": "Destaques do período (opcional).",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "note"],
        "properties": {
          "title": { "type": "string" },
          "note": { "type": "string" },
          "verdict": { "type": "string", "enum": ["vale-agir", "vale-olhar", "casos-especificos", "esperaria", "evitaria", "nao-confirmado"] },
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "sourceEditions": { "type": "array", "items": { "type": "integer" }, "description": "Números das edições Daily de origem (rastreabilidade da consolidação, Fase 2.1)." }
        }
      }
    },
    "watch": { "type": "array", "minItems": 1, "items": { "type": "string" }, "description": "O que monitorar na próxima semana" },
    "sources": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/source" } },
    "disclaimer": {
      "type": "string",
      "const": "Promoções podem mudar sem aviso. Confira sempre as regras no site oficial antes de comprar, transferir ou resgatar."
    }
  },
  "$defs": {
    "radarWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "confidence", "window"],
      "properties": {
        "label": { "type": "string" },
        "confidence": { "type": "string", "enum": ["alta", "media", "baixa"] },
        "window": { "type": "string" },
        "basis": { "type": "string" },
        "bonus": { "type": "string" },
        "source": { "type": "string", "description": "Proveniência (Fase C0): 'forecast' = automático; ausente = análise editorial." },
        "seriesKey": { "type": "string" },
        "generatedAt": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string" },
        "url": { "type": "string", "format": "uri", "pattern": "^https?://" }
      }
    }
  }
}
