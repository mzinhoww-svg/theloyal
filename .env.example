# Beehiiv — credenciais usadas SOMENTE no servidor: app/api/subscribe/route.ts
# (inscricao) e scripts/beehiiv-publish.mjs (publicacao das edicoes).
# Nunca versione o .env real nem exponha estas chaves no client.
# Sem estas variaveis, /api/subscribe e o Publisher operam em modo mock
# (sucesso/dry-run simulado), util para dev e para o preview da Vercel nao quebrar.
# O Create Post exige escopo posts:write (beta/Enterprise).

BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Central de Controle (/admin) — usadas SOMENTE no servidor.
# Senha unica do painel. /admin/login valida contra ela e grava um cookie
# httpOnly (hash SHA-256). Sem ADMIN_TOKEN, o login nao autentica ninguem.
ADMIN_TOKEN=

# Basic Auth legado dos endpoints do Radar (/admin/sku e /admin/collect, que
# tem auth propria). Sem estas duas, esses dois endpoints respondem 401.
ADMIN_USER=
ADMIN_PASSWORD=

# Supabase — motor do painel e do Radar (campanhas, valuations, VPM por SKU).
# URL + anon key sao publicas (RLS protege). A SERVICE key e server-only: o
# painel e o coletor a usam para ler tudo e escrever, ignorando RLS. NUNCA
# exponha a SERVICE key no client. Sem ela, o painel carrega em modo leitura
# vazia. A camada nova (lib/admin-db.ts) aceita SUPABASE_SERVICE_ROLE_KEY ou
# SUPABASE_SERVICE_KEY (mesma chave, nomes diferentes convivendo no deploy).
SUPABASE_URL=https://qjqnqcsdnpvvmyzkavoq.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Coletor de SKUs (scripts/collect-skus.mjs) — descoberta + LLM. Server-only.
# Sem chaves, o coletor roda em modo mock (nao chama API externa, grava payload).
# So dado PUBLICO de catalogo trafega por aqui — nunca cifra interna/CMI.
TAVILY_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Opcional: apontar o cliente LLM para um Ollama local em dev (troca o backend).
# Ex.: OLLAMA_BASE_URL=http://localhost:11434  OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# Admin dispara a rodada do coletor via workflow_dispatch (app/admin/collect).
# Token fine-grained com escopo "actions:write" no repo. Server-only.
GH_DISPATCH_TOKEN=
GH_REPO=mzinhoww-svg/theloyal
GH_COLLECT_WORKFLOW=collect.yml
