# The Loyalty — variaveis de ambiente
# Copie para .env (nunca versionado) e preencha os valores reais.
# Sem estas variaveis, /api/subscribe e o Publisher operam em MODO MOCK
# (sucesso/dry-run simulado), util para dev e para o preview da Vercel nao quebrar.

# --- Beehiiv (server-only) -------------------------------------------------
# Usadas apenas no servidor: app/api/subscribe/route.ts (inscricao) e
# scripts/beehiiv-publish.mjs (publicacao das edicoes). Nunca expor no client.

# Chave da API do Beehiiv. O Create Post exige o escopo posts:write
# (plano beta/Enterprise). Sem ela: modo mock.
BEEHIIV_API_KEY=

# ID da publicacao. Aceita o formato "pub_<uuid>" ou o UUID cru — o codigo
# adiciona o prefixo "pub_" automaticamente se faltar. Sem ele: modo mock.
BEEHIIV_PUBLICATION_ID=

# --- Build (opcional) ------------------------------------------------------
# Desliga a telemetria anonima do Next.js nos builds/CI. Opcional.
NEXT_TELEMETRY_DISABLED=1
