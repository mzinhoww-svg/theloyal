# Beehiiv — credenciais usadas SOMENTE no servidor: app/api/subscribe/route.ts
# (inscricao) e scripts/beehiiv-publish.mjs (publicacao das edicoes).
# Nunca versione o .env real nem exponha estas chaves no client.
# Sem estas variaveis, /api/subscribe e o Publisher operam em modo mock
# (sucesso/dry-run simulado), util para dev e para o preview da Vercel nao quebrar.
# O Create Post exige escopo posts:write (beta/Enterprise).

BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
