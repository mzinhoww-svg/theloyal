# Beehiiv — credenciais usadas SOMENTE no servidor: app/api/subscribe/route.ts
# (inscricao) e scripts/beehiiv-publish.mjs (publicacao das edicoes).
# Nunca versione o .env real nem exponha estas chaves no client.
# Sem estas variaveis, /api/subscribe e o Publisher operam em modo mock
# (sucesso/dry-run simulado), util para dev e para o preview da Vercel nao quebrar.
# O Create Post exige escopo posts:write (beta/Enterprise).

BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Central de Controle (/admin) — usadas SOMENTE no servidor.
# Basic Auth do painel: sem estas duas, /admin/* nega tudo (401).
ADMIN_USER=
ADMIN_PASSWORD=

# Acesso ao Supabase pela camada admin. A SERVICE_ROLE_KEY bypassa RLS e
# habilita as RPCs admin_* — NUNCA exponha no client. Sem ela, o painel
# carrega mas mostra tudo vazio (adminConfigured() = false).
# SUPABASE_URL tem default para o projeto atual; sobrescreva se mudar.
SUPABASE_URL=https://qjqnqcsdnpvvmyzkavoq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
