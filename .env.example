# Beehiiv — credenciais usadas SOMENTE no servidor: app/api/subscribe/route.ts
# (inscricao) e scripts/beehiiv-publish.mjs (publicacao das edicoes).
# Nunca versione o .env real nem exponha estas chaves no client.
# Sem estas variaveis, /api/subscribe e o Publisher operam em modo mock
# (sucesso/dry-run simulado), util para dev e para o preview da Vercel nao quebrar.
# O Create Post exige escopo posts:write (beta/Enterprise).

BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Admin (app/admin/route.ts) — Basic Auth. Sem estas duas, o /admin responde 401.
ADMIN_USER=
ADMIN_PASSWORD=

# Supabase — motor do Radar (campanhas, valuations, VPM observado por SKU).
# URL + publishable(anon) key sao publicas (RLS protege). A SERVICE key e
# server-only: usada pelo /admin e pelo coletor para ler tudo e escrever.
# NUNCA exponha a SERVICE key no client. Sem elas, /admin e o coletor caem em
# modo mock/leitura limitada.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Coletor de SKUs (scripts/collect-skus.mjs) — descoberta + LLM. Server-only.
# Sem chaves, o coletor roda em modo mock (nao chama API externa, grava payload).
# So dado PUBLICO de catalogo trafega por aqui — nunca cifra interna/CMI.
TAVILY_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Opcional: apontar o cliente LLM para um Ollama local em dev (troca o backend).
# Ex.: OLLAMA_BASE_URL=http://localhost:11434  OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=
OLLAMA_MODEL=

# Admin dispara a rodada do coletor via workflow_dispatch (app/api/admin/collect).
# Token fine-grained com escopo "actions:write" no repo. Server-only.
GH_DISPATCH_TOKEN=
GH_REPO=mzinhoww-svg/theloyal
GH_COLLECT_WORKFLOW=collect.yml
